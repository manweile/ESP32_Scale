{
  "version": "2.0.0",
  "inputs": [

    // dynamic com port list from google search: vs code tasks.json input com ports extension "Command Variable"
    // requires the Command Variable extension installed and lists.py script in the PropaneScale folder that uses pyserial to list available COM ports on Windows, 
    {
      "id": "COMPort",
      "type": "command",
      "command": "shellCommand.execute",
      "args": {
          // alternative windows only command: "powershell -Command \"[System.IO.Ports.SerialPort]::GetPortNames()\""
          "command": "python ${workspaceFolder}/PropaneScale/list_ports.py",
          "description": "Select the COM port for upload"
      }
    },

    // esptool.py upload baudrate, 
    // default to 921600 which is a common high speed for ESP32 uploads, 
    // but user can choose a different baudrate if they have stability issues at higher speeds
    {
      "id": "espUploadSpeed",
      "type": "pickString",
      "description": "Upload baudrate",
      "options": [
        "921600",
        "460800",
        "230400",
        "115200"
      ],
      "default": "921600"
    },

    // list of FQBN for the boards I have and are installed in arduino-cli
    // FQBN is colon separated string with format: "package:architecture:board",  
    // used for arduino-cli compile and upload tasks to specify the target board configuration
    {
      "id": "FQBN",
      "type": "pickString",
      "description": "Fully Qualified Board Name (FQBN) to use",
      "options": [
          "esp32:esp32:esp32thing",
          "esp8266:esp8266:thingdev"
      ]
    },

    // list of build dirs for the FQBN of boards I have and are installed in arduino-cli
    // FQBNDIR is dot separated string with format: "package.architecture.board",  
    // used for constructing the path to the pre-built binary for arduino-cli upload task
    {
      "id": "FQBNDIR",
      "type": "pickString",
      "description": "Fully Qualified Board Name (FQBN) build directory to use",
      "options": [
          "esp32.esp32.esp32thing",
          "esp8266.esp8266.thingdev"
      ]
    },

    // Serial monitor baudrate, 
    // default to 115200 which is the most common baudrate for ESP32 serial output, 
    // but user can choose a different baudrate if their board is configured differently
    {
      "id": "monitorBaud",
      "type": "pickString",
      "description": "Serial monitor baudrate",
      "options": [
        "115200",
        "74880",
        "38400",
        "9600"
      ],
      "default": "115200"
    },

    // open a file dialog to select a merged ESP32 binary for esptool upload
    // defaultUri ends in the selected FQBNDIR build folder
    {
      "id": "openMergedBinDialog",
      "type": "command",
      "command": "extension.commandvariable.file.openDialog",
      "args": {
          "canSelect": "files",
      "defaultUri": "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}/",
      "include": "**/${fileBasename}.merged.bin",
          "filters": {
        "Merged BIN": ["merged.bin"]
          }
      }
    },

    // path to openOCD executable, 
    // default to "openocd" which should work if it's in PATH, 
    // otherwise user can provide full path to openocd.exe
    // {
    //   "id": "openocdPath",
    //   "type": "promptString",
    //   "description": "OpenOCD executable path",
    //   "default": "openocd"
    // },
    // // path to openOCD scripts directory, 
    // // which contains interface/ and target/ subdirectories, 
    // // default to the typical installation path for OpenOCD for ESP32 on Windows, 
    // // but user can provide a different path if needed
    // {
    //   "id": "openocdScriptsDir",
    //   "type": "promptString",
    //   "description": "OpenOCD scripts directory (contains interface/ and target/)",
    //   "default": "C:/Espressif/tools/openocd-esp32/share/openocd/scripts"
    // }

  ],

  "tasks": [

    // Arduino-cli tasks

    // FQBN Production Quick Compile
    // arduino-cli compile task with verbose output and no clean build,
    // uses the FQBN input to specify the board configuration,
    // command line: arduino-cli compile -v --fqbn esp32:esp32:esp32thing D:/MyArduino/Projects/ESP32_Scale/PropaneScale
    {
      "label": "FQBN Production Quick Compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--fqbn",
        "${input:FQBN}",
        "${workspaceFolder}/PropaneScale"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // FQBN Production Clean Rebuild
    // arduino-cli compile task with verbose output and clean build, 
    // uses the FQBN input to specify the board configuration, 
    // command line: arduino-cli compile -v --clean --fqbn esp32:esp32:esp32thing D:/MyArduino/Projects/ESP32_Scale/PropaneScale
    {
      "label": "FQBN Production Clean Rebuild",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--clean",
        "--fqbn",
        "${input:FQBN}",
        "${workspaceFolder}/PropaneScale"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // FQBN Debug File Compile
    // arduino-cli compile task with verbose output and clean build,
    // uses the FQBN input to specify the board configuration, 
    // and sets the build.extra_flags property to include -Og for better debugging and -g3 for maximum debug info in the binary
    // command line: arduino-cli compile -v --clean --fqbn esp32:esp32:esp32thing --build-property "build.extra_flags=-Og -g3" D:/MyArduino/Projects/ESP32_Scale/PropaneScale
    {
      "label": "FQBN Debug File Compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--clean",
        "--fqbn",
        "${input:FQBN}",
        "--build-property",
        "build.extra_flags=-Og -g3",
        "${workspaceFolder}/PropaneScale"
      ],
      "problemMatcher": []
    },

    // COMPort & FQBN & FQBNDIR USB Upload
    // arduino-cli upload task using COM port, FQBN, and FQBNDIR inputs
    // to specify the serial port, board configuration, and build directory for the pre-built binary
    // command line: arduino-cli upload -v -p COM4 --fqbn esp32:esp32:esp32thing 
    // --input-dir D:/MyArduino/Projects/ESP32_Scale/PropaneScale/build/esp32.esp32.esp32thing D:/MyArduino/Projects/ESP32_Scale/PropaneScale
    {
      "label": "COMPort & FQBN & FQBNDIR USB Upload",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "upload",
        "-v",
        "-p",
        "${input:COMPort}",
        "--fqbn",
        "${input:FQBN}",
        "--input-dir",
        "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}",
        "${workspaceFolder}/PropaneScale"
      ],
      "problemMatcher": []
    },

    // COMPort & Baud & FQBN Select USB Serial Monitor
    // arduino-cli monitor task using COM port, FQBN, and baudrate inputs to open a serial monitor for the specified board and port
    // command line: arduino-cli monitor -p COM4 --config baudrate=115200 --fqbn esp32:esp32:esp32thing D:/MyArduino/Projects/ESP32_Scale/PropaneScale
    {
      "label": "COMPort & Baud & FQBN Select USB Serial Monitor",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "monitor",
        "-p",
        "${input:COMPort}",
        "--config",
        "baudrate=${input:monitorBaud}",
        "--fqbn",
        "${input:FQBN}"
      ],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": []
    },

    // Arduino-CLI for ESP32 Thing tasks

    // ESP32 Thing Quick Compile
    // arduino-cli compile task for ESP32 Thing with verbose output and clean build,
    // uses the esp32:esp32:esp32thing FQBN to specify the board configuration
    // command line: arduino-cli compile --clean --fqbn esp32:esp32:esp32thing D:/MyArduino/Projects/ESP32_Scale/PropaneScale
    {
      "label": "ESP32 Thing Quick Compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--fqbn",
        "esp32:esp32:esp32thing",
        "${workspaceFolder}/PropaneScale"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ESP32 Thing Clean Rebuild
    // arduino-cli compile task for ESP32 Thing with verbose output and clean build,
    // uses the esp32:esp32:esp32thing FQBN to specify the board configuration,
    // command line: arduino-cli compile -v --clean --fqbn esp32:esp32:esp32thing D:/MyArduino/Projects/ESP32_Scale/PropaneScale
    {
      "label": "ESP32 Thing Clean Rebuild",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--clean",
        "--fqbn",
        "esp32:esp32:esp32thing",
        "${workspaceFolder}/PropaneScale"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    
    // Powershell tasks
    
    // ESP32 Thing Quick Flash
    // ESPTool flash task for ESP32 Thing,
    // uses the list_ports.py return ran by powershell to specify the serial port,
    // uses esp32 chip type and 921600 baudrate for fast uploads,
    // use the ${workspaceFolder} variable to construct the path to the merged binary,
    // command line: esptool.exe --verbose --chip esp32 --port COM3 --baud 921600 write-flash -z 0x0 D:/MyArduino/Projects/ESP32_Scale/PropaneScale/build/esp32.esp32.esp32thing/PropaneScale.ino.merged.bin
    {
      "label": "ESP32 Thing Quick Flash",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/esp32-thing-quick-flash.ps1",
        "-WorkspaceFolder",
        "${workspaceFolder}"
      ],
      "problemMatcher": []
    },

    // ESPTool tasks

    // ESPTool ESP32 COMPort Merged Bin Upload
    // a shell task to run the ESPTool flash command for ESP32
    // using esp32 chip, the COM port input, fixed baudrate of 921600, 
    // and the merged binary path constructed from the workspace folder and fileBasename variables
    // command line: esptool.exe --verbose --chip esp32 --port COM4 --baud 921600 write-flash -z 0x0 
    // D:/MyArduino/Projects/ESP32_Scale/PropaneScale/build/esp32.esp32.esp32thing/PropaneScale.ino.merged.bin
    {
      "label": "ESPTool ESP32 COMPort Merged Bin Upload",
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Arduino15/packages/esp32/tools/esptool_py/5.1.0/esptool.exe",
      "args": [
        "--verbose",
        "--chip",
        "esp32",
        "--port",
        "${input:COMPort}",
        "--baud",
        "921600",
        "write-flash",
        "-z",
        "0x0",
        "${workspaceFolder}/PropaneScale/build/esp32.esp32.esp32thing/${fileBasename}.merged.bin"
      ],
      "problemMatcher": []
    },

    // ESPTool COMPort Erase Flash
    // a shell task to run the ESPTool erase_flash command
    // uses esp32 chip and COM port input
    // command line: esptool.exe --chip esp32 --port COM4 erase_flash
    {
      "label": "ESPTool COMPort Erase Flash",
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Arduino15/packages/esp32/tools/esptool_py/5.1.0/esptool.exe",
      "args": [
        "--chip",
        "esp32",
        "--port",
        "${input:COMPort}",
        "erase_flash"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // Hidden tasks 

    // FQBNDIR with Bin Warning
    // a hidden shell task to echo the selected FQBNDIR and a warning about the merged binary, 
    // used as a pre-task for ESPTool uploads to ensure the user has selected the correct build directory 
    // and is aware that the merged binary must exist before uploading
    // command line: echo "Selected build dir: esp32.esp32.esp32thing" "WARNING: The PropaneScale.ino.merged.bin file MUST exist before upload"
    {
      "label": "FQBNDIR with Bin Warning",
      "hide": true,
      "type": "shell",
      "command": "echo",
      "args": [
        "Selected build dir: ${input:FQBNDIR}",
        "WARNING: The ${fileBasename}.merged.bin file MUST exist before upload"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ESPTool COMPort & ESP Speed & Merged Bin Dialog Flash
    // a hidden shell task to run the ESPTool flash command for ESP32,
    // used as a pre-task for the ESPTool upload to ensure the user has selected the correct COM port, baudrate, and binary path before uploading
    // uses esp32 chip, COM port input returned by list_ports.py, espUploadSpeed input baudrate for uploads,
    // and the open file dialog input to specify the path to the merged binary
    // command line: esptool.exe --verbose --chip esp32 --port COM3 --baud 921600 write-flash -z 0x0 
    // D:/MyArduino/Projects/ESP32_Scale/PropaneScale/build/esp32.esp32.esp32thing/PropaneScale.ino.merged.bin
    {
      "label": "ESPTool COMPort & ESP Speed & Merged Bin Dialog Flash",
      "hide": true,
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Arduino15/packages/esp32/tools/esptool_py/5.1.0/esptool.exe",
      "args": [
        "--verbose",
        "--chip",
        "esp32",
        "--port",
        "${input:COMPort}",
        "--baud",
        "${input:espUploadSpeed}",
        "write-flash",
        "-z",
        "0x0",
        "${input:openMergedBinDialog}"
      ],
      "problemMatcher": []
    },

    // compound tasks
    
    // ESP32 Thing Quick Compile & Quick Flash
    // compound task to first compile with arduino-cli and then flash with ESPTool, for ESP32 Thing,
    {
      "label": "ESP32 Thing Quick Compile & Quick Flash",
      "dependsOrder": "sequence",
      "dependsOn": [
        "ESP32 Thing Quick Compile",
        "ESP32 Thing Quick Flash"
      ],
      "problemMatcher": []
    },

    // ESPTool USB Upload
    // a compound task to first echo the selected FQBNDIR and a warning about the merged binary, 
    // then echo the selected COM port, baudrate, and merged binary path, and finally run the ESPTool flash command for ESP32,
    {
      "label": "ESPTool USB Upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "FQBNDIR with Bin Warning",
        "ESPTool COMPort & ESP Speed & Merged Bin Dialog Flash"
      ],
      "problemMatcher": []
    },

    // ESP32 Thing Quick Compile + ESPTool Upload
    // a compound task to first compile the ESP32 Thing sketch with arduino-cli and then flash with ESPTool, for ESP32 Thing,
    // ensures the user has selected the correct COM port, baudrate, and binary path before uploading by including the pre-task to echo those values and warnings
    {
      "label": "ESP32 Thing Quick Compile + ESPTool Upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "ESP32 Thing Quick Compile",
        "ESPTool COMPort USB Merged Bin Upload"
      ],
      "problemMatcher": []
    },

    // ESP32 Thing Clean Rebuild + ESPTool Upload
    // a compound task to first clean build the ESP32 Thing sketch with arduino-cli and then flash with ESPTool, for ESP32 Thing,
    // ensures the user has selected the correct COM port, baudrate, and binary path before uploading by including the pre-task to echo those values and warnings
    {
      "label": "ESP32 Thing Clean Rebuild + ESPTool Upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "ESP32 Thing Clean Rebuild",
        "ESPTool ESP32 COMPort Merged Bin Upload"
      ],
      "problemMatcher": []
    }
  ]
}
