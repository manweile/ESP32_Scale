{
  "version": "2.0.0",
  "inputs": [

    // dynamic com port list from google search: vs code tasks.json input com ports extension "Command Variable"
    // requires the Command Variable extension installed and lists.py script in the PropaneScale folder that uses pyserial to list available COM ports on Windows, 
    {
      "id": "COMPort",
      "type": "command",
      "command": "shellCommand.execute",
      "args": {
          // alternative windows only command: "powershell -Command \"[System.IO.Ports.SerialPort]::GetPortNames()\""
          "command": "python ${workspaceFolder}/PropaneScale/list_ports.py",
          "description": "Select the COM port for upload"
      }
    },

    // esptool.py upload baudrate, 
    // default to 921600 which is a common high speed for ESP32 uploads, 
    // but user can choose a different baudrate if they have stability issues at higher speeds
    {
      "id": "espUploadSpeed",
      "type": "pickString",
      "description": "Upload baudrate",
      "options": [
        "921600",
        "460800",
        "230400",
        "115200"
      ],
      "default": "921600"
    },

    // list of FQBN for the boards I have and are installed in arduino-cli
    // FQBN is colon separated string with format: "package:architecture:board",  
    // used for arduino-cli compile and upload tasks to specify the target board configuration
    {
      "id": "FQBN",
      "type": "pickString",
      "description": "Fully Qualified Board Name (FQBN) to use",
      "options": [
          "esp32:esp32:esp32thing",
          "esp8266:esp8266:thingdev"
      ]
    },

    // list of build dirs for the FQBN of boards I have and are installed in arduino-cli
    // FQBNDIR is dot separated string with format: "package.architecture.board",  
    // used for constructing the path to the pre-built binary for arduino-cli upload task
    {
      "id": "FQBNDIR",
      "type": "pickString",
      "description": "Fully Qualified Board Name (FQBN) build directory to use",
      "options": [
          "esp32.esp32.esp32thing",
          "esp8266.esp8266.thingdev"
      ]
    },

    // Serial monitor baudrate, 
    // default to 115200 which is the most common baudrate for ESP32 serial output, 
    // but user can choose a different baudrate if their board is configured differently
    {
      "id": "monitorBaud",
      "type": "pickString",
      "description": "Serial monitor baudrate",
      "options": [
        "115200",
        "74880",
        "38400",
        "9600"
      ],
      "default": "115200"
    },

    // open a file dialog to select a merged ESP32 binary for esptool upload
    // defaultUri ends in the selected FQBNDIR build folder
    {
      "id": "openMergedBinDialog",
      "type": "command",
      "command": "extension.commandvariable.file.openDialog",
      "args": {
          "canSelect": "files",
      "defaultUri": "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}/",
      "include": "**/${fileBasename}.merged.bin",
          "filters": {
        "Merged BIN": ["merged.bin"]
          }
      }
    },

    // path to openOCD executable, 
    // default to "openocd" which should work if it's in PATH, 
    // otherwise user can provide full path to openocd.exe
    // {
    //   "id": "openocdPath",
    //   "type": "promptString",
    //   "description": "OpenOCD executable path",
    //   "default": "openocd"
    // },
    // // path to openOCD scripts directory, 
    // // which contains interface/ and target/ subdirectories, 
    // // default to the typical installation path for OpenOCD for ESP32 on Windows, 
    // // but user can provide a different path if needed
    // {
    //   "id": "openocdScriptsDir",
    //   "type": "promptString",
    //   "description": "OpenOCD scripts directory (contains interface/ and target/)",
    //   "default": "C:/Espressif/tools/openocd-esp32/share/openocd/scripts"
    // }

  ],

  "tasks": [

    /** 
     * Arduino-cli tasks to compile and upload the sketch using arduino-cli directly from the command line
     * all arduino-cli tasks require arduino-cli path in User and/or System PATH
     * and a properly configured & located arduino-cli.yaml file
     */

    // Arduino CLI Production Quick Compile task compiles the sketch without cleaning the build directory for faster incremental builds, 
    // if there are significant changes to the code or dependencies run the "Arduino-CLI Production Clean Rebuild" task to force a full rebuild
    // arduino-cli compile -v --fqbn esp32:esp32:esp32thing D:\MyArduino\Projects\ESP32_Scale/PropaneScale
    {
      "label": "Arduino-CLI Production Quick Compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--fqbn", "${input:FQBN}",
        "${workspaceFolder}/PropaneScale"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "shared"
      },
      "problemMatcher": []
    },

    // quick compile task pinned to ESP32 Thing FQBN to avoid board selection prompts
    // arduino-cli compile -v --fqbn esp32:esp32:esp32thing D:\MyArduino\Projects\ESP32_Scale/PropaneScale
    {
      "label": "ESP32 Thing Arduino-CLI Quick Compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--fqbn", "esp32:esp32:esp32thing",
        "${workspaceFolder}/PropaneScale"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // full clean rebuild compile task pinned to ESP32 Thing FQBN to avoid board selection prompts
    // arduino-cli compile -v --fqbn esp32:esp32:esp32thing D:\MyArduino\Projects\ESP32_Scale/PropaneScale
    {
      "label": "ESP32 Thing Arduino-CLI Clean Rebuild",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--clean",
        "--fqbn", "esp32:esp32:esp32thing",
        "${workspaceFolder}/PropaneScale"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // Arduino CLI Production Clean Rebuild task compiles the sketch with the --clean flag, 
    // forces a full rebuild from scratch, but takes longer to complete
    // arduino-cli compile -v --clean --fqbn esp32:esp32:esp32thing D:\MyArduino\Projects\ESP32_Scale/PropaneScale
    {
      "label": "Arduino-CLI Production Clean Rebuild",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--clean",
        "--fqbn", "${input:FQBN}",
        "${workspaceFolder}/PropaneScale"
      ],
      "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "shared"
      },
      "problemMatcher": []
    },

    // Arduino CLI Debug File Compile task compiles the sketch with the --clean flag and extra debug flags, 
    // forces a full rebuild from scratch, includes debug symbols and disables optimizations,  results in much bigger file
    // arduino-cli compile -v --fqbn esp32:esp32:esp32thing --build-property 'build.extra_flags=-Og -g3' D:\MyArduino\Projects\ESP32_Scale/PropaneScale
    {
      "label": "Arduino-CLI Debug File Compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "-v",
        "--clean",
        "--fqbn", "${input:FQBN}",
        "--build-property", "build.extra_flags=-Og -g3",
        "${workspaceFolder}/PropaneScale"
      ],
      "problemMatcher": []
    },

    // task to upload the sketch using USB serial via arduino-cli directly,
    // using --input-dir to upload the pre-built binary from the build directory
    // arduino-cli upload -v -p COM4 --fqbn esp32:esp32:esp32thing --input-dir D:\MyArduino\Projects\ESP32_Scale/PropaneScale/build/esp32.esp32.esp32thing D:\MyArduino\Projects\ESP32_Scale/PropaneScale
    {
      "label": "Arduino CLI USB Upload",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "upload",
        "-v",
        "-p", "${input:COMPort}",
        "--fqbn", "${input:FQBN}",
        "--input-dir", "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}",
        "${workspaceFolder}/PropaneScale"
      ],
      "problemMatcher": []
    },

    // task to open com port for monitoring using arduino-cli directly
    // runs in a dedicated terminal tab named "Arduino CLI USB Serial Monitor"
    // arduino-cli monitor -p COM4 --config baudrate=115200 --fqbn esp32:esp32:esp32thing
    {
      "label": "Arduino CLI USB Serial Monitor",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "monitor",
        "-p", "${input:COMPort}",
        "--config", "baudrate=${input:monitorBaud}",
        "--fqbn", "${input:FQBN}"
      ],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": []
    },

    /**
     * ESPTool tasks
     * these tasks use esptool.exe directly to either upload the pre-compiled binary or merge the binary components into a single file
     * requires esptool.exe which is included with the esp32 arduino core installation in the arduino15 directory
     */

    // helper task to prompt FQBNDIR before opening the file picker
    // with warning that the selected base filename .merged.bin file MUST already exist
    {
      "label": "ESPTool Select FQBNDIR with Bin Warning",
      "hide": true,
      "type": "shell",
      "command": "echo",
      "args": [
        "Selected build dir: ${input:FQBNDIR}",
        "WARNING: The ${fileBasename}.merged.bin file MUST exist before upload"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // helper task that uploads selected merged binary using esptool.exe
    // esptool.exe --verbose --chip esp32 --port COM4 --baud 921600 write-flash -z 0x0 D:\MyArduino\Projects\ESP32_Scale/build/esp32.esp32.esp32thing/PropaneScale.ino.merged.bin
    {
      "label": "ESPTool USB Select Bin Upload",
      "hide": true,
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Arduino15/packages/esp32/tools/esptool_py/5.1.0/esptool.exe",
      "args": [
        "--verbose",
        "--chip", "esp32",
        "--port", "${input:COMPort}",
        "--baud", "${input:espUploadSpeed}",
        "write-flash",
        "-z",
        "0x0",
        "${input:openMergedBinDialog}"
      ],
      "problemMatcher": []
    },

    // upload task using ESP32 chip, com port selected from propmpt, set speed, and merged output file from compile
    // esptool.exe --verbose --chip esp32 --port COM4 --baud 921600 write-flash -z 0x0 
    // D:\MyArduino\Projects\ESP32_Scale/PropaneScale/build/esp32.esp32.esp32thing/PropaneScale.ino.merged.bin
    {
      "label": "ESPTool USB Merged Bin Upload",
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Arduino15/packages/esp32/tools/esptool_py/5.1.0/esptool.exe",
      "args": [
        "--verbose",
        "--chip", "esp32",
        "--port", "${input:COMPort}",
        "--baud", "921600",
        "write-flash",
        "-z",
        "0x0",
        "${workspaceFolder}/PropaneScale/build/esp32.esp32.esp32thing/${fileBasename}.merged.bin"
      ],
      "problemMatcher": []
    },

    // erase entire flash for clean EEPROM/default-init logic tests
    // esptool.exe --chip esp32 --port COM4 erase_flash
    {
      "label": "ESPTool Erase Flash (EEPROM Test)",
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Arduino15/packages/esp32/tools/esptool_py/5.1.0/esptool.exe",
      "args": [
        "--chip", "esp32",
        "--port", "${input:COMPort}",
        "erase_flash"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // wrapper task to ensure FQBNDIR prompt appears before the file dialog
    {
      "label": "ESPTool USB Upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "ESPTool Select FQBNDIR with Bin Warning",
        "ESPTool USB Select Bin Upload"
      ],
      "problemMatcher": []
    },

    // one-click flow: quick compile for ESP32 Thing and upload the direct merged.bin artifact
    {
      "label": "ESP32 Thing Arduino-CLI Quick Compile + ESPTool Upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "ESP32 Thing Arduino-CLI Quick Compile",
        "ESPTool USB Merged Bin Upload"
      ],
      "problemMatcher": []
    },

    // one-click flow: clean rebuild compile for ESP32 Thing and upload the direct merged.bin artifact
    {
      "label": "ESP32 Thing Arduino-CLI Clean Rebuild + ESPTool Upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "ESP32 Thing Arduino-CLI Clean Rebuild",
        "ESPTool USB Merged Bin Upload"
      ],
      "problemMatcher": []
    }

    // task to generate a single production image using esptool.exe only
    // requires existing .bootloader.bin, .partitions.bin, and .bin artifacts
    // %LOCALAPPDATA%/Arduino15/packages/esp32/tools/esptool_py/5.1.0/esptool.exe 
    // --chip esp32 merge-bin -o PropaneScale.ino.merged.bin 
    // 0x1000 PropaneScale.ino.bootloader.bin 0x8000 PropaneScale.ino.partitions.bin 0x10000 PropaneScale.ino.bin
    // {
    //   "label": "ESPTool Production File Compile",
