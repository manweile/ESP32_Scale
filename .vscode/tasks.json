    //     "--verbose", "--chip", "esp32",
    //     "merge-bin",
    //     "-o", "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}/${fileBasename}.merged.bin",
    //     "0x1000", "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}/${fileBasename}.bootloader.bin",
    //     "0x8000", "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}/${fileBasename}.partitions.bin",
    //     "0x10000", "${workspaceFolder}/PropaneScale/build/${input:FQBNDIR}/${fileBasename}.bin"
    //   ],
    //   "problemMatcher": []
    // },

    /**
     * JTAG OpenOCD tasks
     * these tasks use OpenOCD to program and debug the ESP32 using the ESP-Prog JTAG debugger
     * requires OpenOCD with the appropriate configuration file for the ESP32 and ESP-Prog, 
     * and the arduino-cli-auto.ps1 script to handle uploads and serial monitoring via OpenOCD
     */

