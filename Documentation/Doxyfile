# Doxyfile for PropaneScale (ESP32_Scale)
# Generated/edited to document the PropaneScale sketch and src/ folder.

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "PropaneScale"
PROJECT_NUMBER         = 
PROJECT_BRIEF          = "ESP32 Propane Scale firmware"
OUTPUT_DIRECTORY       = doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English

# Input
INPUT                  = ../PropaneScale/src ../PropaneScale
RECURSIVE              = YES
FILE_PATTERNS          = *.c *.cc *.cpp *.h *.hpp *.ino *.md
EXTENSION_MAPPING      = ino=C++
STRIP_FROM_PATH        = ../PropaneScale
STRIP_FROM_INC_PATH    = 

# Parsing & extraction
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 6
AUTOLINK_SUPPORT       = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_UNDOC_NAMESPACES  = YES
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = NO

# Output formatting
FULL_PATH_NAMES        = YES
SHORT_NAMES            = NO
JAVADOC_AUTOBRIEF      = NO
MULTILINE_CPP_IS_BRIEF = NO

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO

# Exclude build artifacts
EXCLUDE                = ../PropaneScale/build
EXCLUDE_PATTERNS       = 

# Performance
NUM_PROC_THREADS       = 4
LOOKUP_CACHE_SIZE      = 0

# Output formats
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES

# Misc
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST= YES

# File display
SHOW_INCLUDE_FILES     = YES
SHOW_HEADERFILE        = YES

# Sorting
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES

# Tips: Run from Documentation folder:
#   doxygen Doxyfile
# Output will be in Documentation/doxygen/html
